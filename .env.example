# Leave empty for Vercel / local dev (root deployment).
# Set to /medifi-base-hub for GitHub Pages (CI sets this automatically).
NEXT_PUBLIC_BASE_PATH=

NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# Server-only Etherscan API V2 key for Base (chainid 8453). Set on Vercel — never NEXT_PUBLIC_.
# Contract analytics call /api/contracts/* route handlers; keys are not exposed to the browser.
BASESCAN_API_KEY=your_etherscan_api_key

# Deprecated — do not use for contract fetches (removed from client-side Basescan calls).
# NEXT_PUBLIC_BASESCAN_API_KEY=

# GitHub PAT for commit counts and repo analytics (client-side for static export).
# GITHUB_PERSONAL_ACCESS_TOKEN is a server-only alias; prefer NEXT_PUBLIC_ for GitHub Pages.
NEXT_PUBLIC_GITHUB_PERSONAL_ACCESS_TOKEN=your_token_here
GITHUB_PERSONAL_ACCESS_TOKEN=
